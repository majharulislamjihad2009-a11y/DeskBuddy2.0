String makeAiPrompt() {
  String p = "";
  p += "You are DeskBuddy, a tiny OLED desk companion. ";
  p += "Give a short, inspiring quote from a famous person (e.g., Einstein, Confucius, etc.). ";
  p += "The quote must be 1-2 lines max. Include the author. No commentary. ";
  p += "Make it fresh each time. Return only the quote and author.";
  return p;
}

String extractAndCleanResponse(String payload) {
  JSONVar doc = JSON.parse(payload);
  if (JSON.typeof(doc) == "undefined") {
    int contentStart = payload.indexOf("\"content\":\"");
    if (contentStart == -1) contentStart = payload.indexOf("\"content\": \"");
    if (contentStart != -1) {
      contentStart += 11;
      int contentEnd = payload.indexOf("\"", contentStart);
      while (contentEnd != -1 && contentEnd > 0 && payload.charAt(contentEnd - 1) == '\\') {
        contentEnd = payload.indexOf("\"", contentEnd + 1);
      }
      if (contentEnd != -1) {
        String content = payload.substring(contentStart, contentEnd);
        content.replace("\\n", "\n");
        content.replace("\\\"", "\"");
        content.replace("\\\\", "\\");
        content.replace("\\t", "\t");
        content.replace("\\r", "\r");
        return content;
      }
    }
    return "Error: No quote.";
  }

  if (!doc.hasOwnProperty("choices") || doc["choices"].length() == 0) return "No choices.";
  JSONVar choice = doc["choices"][0];
  if (!choice.hasOwnProperty("message")) return "No message.";
  JSONVar msg = choice["message"];
  if (!msg.hasOwnProperty("content")) return "No content.";

  String content = (const char*)msg["content"];

  content.replace("```", "");
  content.replace("**", "");
  content.replace("*", "");
  content.replace("#", "");
  content.replace("`", "");
  content.replace("\\n", "\n");
  content.replace("\\\"", "\"");
  content.replace("\\\\", "\\");
  content.replace("\\t", "\t");
  content.replace("\\r", "\r");

  content.trim();
  if (content.length() == 0) return "...";
  return content;
}

String fetchAiLineOpenRouter() {
  if (WiFi.status() != WL_CONNECTED) return "No WiFi — I’m still cheering for you!";
  if (openrouterApiKey.length() < 20) return "Set OpenRouter key in portal to unlock AI ✨";

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient https;

  if (!https.begin(client, OR_URL)) {
    return "Connection failed.";
  }

  https.addHeader("Content-Type", "application/json");
  https.addHeader("Authorization", "Bearer " + openrouterApiKey);
  https.addHeader("X-Title", "DeskBuddy-OLED");

  String userPrompt = makeAiPrompt();

  String body = "{";
  body += "\"model\":\"" + String(OR_MODEL) + "\",";
  body += "\"max_tokens\":150,";
  body += "\"temperature\":0.8,";
  body += "\"messages\":[";
  body += "{\"role\":\"system\",\"content\":\"You are DeskBuddy, a tiny OLED desk companion. Give a short, inspiring quote from a famous person. The quote must be 1-2 lines max. Include the author. No commentary. Return only the quote and author.\"},";
  body += "{\"role\":\"user\",\"content\":\"" + userPrompt + "\"}";
  body += "]}";

  int httpCode = https.POST(body);
  if (httpCode <= 0) {
    https.end();
    return "AI request failed.";
  }

  String resp = https.getString();
  https.end();

  return extractAndCleanResponse(resp);
}

void startAiPopupIfAllowed() {
  unsigned long now = millis();
  if (aiPopupActive) return;
  if (now - lastAiCall < AI_COOLDOWN_MS) {
    aiLastText = "Cooldown… try again in a moment ";
    aiPopupActive = true;
    aiPopupStart = now;
    return;
  }
  lastAiCall = now;

  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  drawCenteredText("Thinking...", 28);
  display.display();

  aiLastText = fetchAiLineOpenRouter();

  aiLineCount = 0;
  String remaining = aiLastText;
  while (remaining.length() > 0 && aiLineCount < 20) {
    if (remaining.length() <= 20) {
      aiLines[aiLineCount++] = remaining;
      break;
    }
    int cut = 20;
    for (int i = 20; i > 10; i--) {
      if (remaining[i] == ' ') { cut = i; break; }
    }
    aiLines[aiLineCount++] = remaining.substring(0, cut);
    remaining = remaining.substring(cut);
    remaining.trim();
  }
  aiScrollOffset = 0;
  maxScrollOffset = (aiLineCount > 4) ? aiLineCount - 4 : 0;

  aiPopupActive = true;
  aiPopupStart = now;
}

void closeAiPopup() {
  aiPopupActive = false;
}

