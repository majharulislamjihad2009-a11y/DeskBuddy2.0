// ==================================================
void getWeatherAndForecast() {
  if (WiFi.status() != WL_CONNECTED) return;
  if (apiKey.length() < 10) return;

  // --- Current weather ---
  HTTPClient http;
  String url = "http://api.openweathermap.org/data/2.5/weather?q=" + city + "," + countryCode + "&appid=" + apiKey + "&units=metric";
  http.begin(url);
  if (http.GET() == 200) {
    String payload = http.getString();
    JSONVar myObject = JSON.parse(payload);
    if (JSON.typeof(myObject) != "undefined") {
      temperature = double(myObject["main"]["temp"]);
      feelsLike = double(myObject["main"]["feels_like"]);
      humidity = int(myObject["main"]["humidity"]);
      weatherMain = (const char*)myObject["weather"][0]["main"];
      weatherDesc = (const char*)myObject["weather"][0]["description"];
      if (weatherDesc.length() > 0) weatherDesc[0] = toupper(weatherDesc[0]);
      if (myObject.hasOwnProperty("timezone")) {
        weatherTzOffsetSec = int(myObject["timezone"]); // seconds from UTC
      }
      updateMoodBasedOnWeather();
    }
  }
  http.end();

  // --- Forecast ---
  url = "http://api.openweathermap.org/data/2.5/forecast?q=" + city + "," + countryCode + "&appid=" + apiKey + "&units=metric";
  http.begin(url);
  if (http.GET() == 200) {
    String payload = http.getString();
    JSONVar fo = JSON.parse(payload);
    if (JSON.typeof(fo) != "undefined" && fo.hasOwnProperty("list")) {
      if (fo.hasOwnProperty("city") && fo["city"].hasOwnProperty("timezone")) {
        weatherTzOffsetSec = int(fo["city"]["timezone"]);
      }

      auto pickIndexForDay = [&](int targetWday, int targetYday) -> int {
        int bestIdx = -1;
        long bestScore = 2147483647L;

        int n = fo["list"].length();
        for (int i = 0; i < n; i++) {
          long dt = (long)fo["list"][i]["dt"];   // UTC epoch
          long local = dt + weatherTzOffsetSec;  // city local epoch
          struct tm tmL;
          time_t tt = (time_t)local;
          gmtime_r(&tt, &tmL);

          if (tmL.tm_yday != targetYday) continue;
          if (tmL.tm_wday != targetWday) continue;

          long mins = tmL.tm_hour * 60 + tmL.tm_min;
          long score = labs(mins - (12 * 60)); // closest to 12:00 local
          if (score < bestScore) { bestScore = score; bestIdx = i; }
        }
        return bestIdx;
      };

      time_t nowUtc;
      time(&nowUtc);
      time_t nowLocal = nowUtc + weatherTzOffsetSec;
      struct tm nowL;
      gmtime_r(&nowLocal, &nowL);

      const char* days[] = { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };

      for (int d = 1; d <= 3; d++) {
        int targetWday = (nowL.tm_wday + d) % 7;

        // safer yday wrap (handles year edges)
        int targetYday = nowL.tm_yday + d;
        if (targetYday > 365) targetYday -= 366;

        int idx = pickIndexForDay(targetWday, targetYday);
        if (idx < 0) {
          idx = min((int)fo["list"].length() - 1, d * 8);
        }

        fcast[d - 1].temp = (int)double(fo["list"][idx]["main"]["temp"]);
        fcast[d - 1].iconType = (const char*)fo["list"][idx]["weather"][0]["main"];
        fcast[d - 1].dayName = days[targetWday];
      }
    }
  }
  http.end();
}

