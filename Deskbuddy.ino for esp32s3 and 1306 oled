void pomoResetToMode() {
  pomoOnBreak = false;
  pomoRunning = false;
  pomoRemainSec = modes[pomoModeIndex].workSec;
}

void pomoTick() {
  if (!pomoRunning) return;
  unsigned long now = millis();
  if (pomoLastTickMs == 0) pomoLastTickMs = now;

  while (now - pomoLastTickMs >= 1000) {
    pomoLastTickMs += 1000;
    if (pomoRemainSec > 0) {
      pomoRemainSec--;
    } else {
      pomoOnBreak = !pomoOnBreak;
      pomoRemainSec = pomoOnBreak ? modes[pomoModeIndex].breakSec : modes[pomoModeIndex].workSec;
    }
  }
}

void drawPomodoroPage() {
  pomoTick();

  display.setTextColor(SSD1306_WHITE);
  display.setFont(NULL);

  display.fillRect(0, 0, 128, 16, SSD1306_WHITE);
  display.setTextColor(SSD1306_BLACK);
  display.setCursor(8, 4);
  display.print("POMODORO ");
  display.print(modes[pomoModeIndex].name);

  display.setTextColor(SSD1306_WHITE);

  display.setCursor(8, 22);
  display.print(pomoOnBreak ? "BREAK" : "FOCUS");
  display.setCursor(80, 22);
  display.print(pomoRunning ? "RUN" : "PAUSE");

  uint32_t sec = pomoRemainSec;
  uint32_t mm = sec / 60;
  uint32_t ss = sec % 60;

  char buf[10];
  sprintf(buf, "%02lu:%02lu", (unsigned long)mm, (unsigned long)ss);

  display.setFont(&FreeSansBold18pt7b);
  int16_t x1, y1;
  uint16_t w, h;
  display.getTextBounds(buf, 0, 0, &x1, &y1, &w, &h);
  display.setCursor((SCREEN_WIDTH - w) / 2, 52);
  display.print(buf);

  uint32_t total = pomoOnBreak ? modes[pomoModeIndex].breakSec : modes[pomoModeIndex].workSec;
  float p = (total == 0) ? 0 : (1.0f - (float)pomoRemainSec / (float)total);
  int barW = 112;
  int filled = (int)(barW * p);

  display.drawRect(8, 56, barW, 6, SSD1306_WHITE);
  display.fillRect(9, 57, max(0, min(filled, barW - 2)), 4, SSD1306_WHITE);
}

