/*
  One unified portal runner
  - firstBootOrAutoConnect = true  => autoConnect("DeskBuddy-Setup")
  - firstBootOrAutoConnect = false => startConfigPortal("DeskBuddy-Setup")
*/
bool runWiFiManagerPortal(bool firstBootOrAutoConnect) {
  loadPreferences();

  WiFiManager wm;
  wm.setConfigPortalTimeout(180);

  // dropdown UI block
  String html = buildPortalPresetsHTML();
  WiFiManagerParameter p_html(html.c_str());
  wm.addParameter(&p_html);

  // editable fields
  WiFiManagerParameter p_or_key("or_key", "OpenRouter API Key", openrouterApiKey.c_str(), 90);
  WiFiManagerParameter p_weather_key("weather_key", "OpenWeatherMap API Key", apiKey.c_str(), 40);
  WiFiManagerParameter p_city("city", "Weather City (manual)", city.c_str(), 40);
  WiFiManagerParameter p_country("country", "Country Code (manual, e.g., BD)", countryCode.c_str(), 10);

  char tzb[10];
  snprintf(tzb, 10, "%d", tzOffsetMinutes);
  WiFiManagerParameter p_tzm("tzm", "Timezone Offset Minutes (manual, Dhaka=360)", tzb, 10);

  char buf1[10], buf2[10];
  snprintf(buf1, 10, "%d", worldOffset1);
  snprintf(buf2, 10, "%d", worldOffset2);

  WiFiManagerParameter p_wc1("wc1", "World Clock City 1 (manual)", worldCity1.c_str(), 20);
  WiFiManagerParameter p_wo1("wo1", "Offset 1 minutes (manual)", buf1, 10);
  WiFiManagerParameter p_wc2("wc2", "World Clock City 2 (manual)", worldCity2.c_str(), 20);
  WiFiManagerParameter p_wo2("wo2", "Offset 2 minutes (manual)", buf2, 10);

  wm.addParameter(&p_or_key);
  wm.addParameter(&p_weather_key);
  wm.addParameter(&p_city);
  wm.addParameter(&p_country);
  wm.addParameter(&p_tzm);
  wm.addParameter(&p_wc1);
  wm.addParameter(&p_wo1);
  wm.addParameter(&p_wc2);
  wm.addParameter(&p_wo2);

  display.clearDisplay();
  drawCenteredText(firstBootOrAutoConnect ? "WiFi setup..." : "Config Mode...", 26);
  display.display();

  bool ok = false;
  if (firstBootOrAutoConnect) {
    ok = wm.autoConnect("DeskBuddy-Setup");
  } else {
    WiFi.disconnect(true, true);
    delay(200);
    ok = wm.startConfigPortal("DeskBuddy-Setup");
  }

  // Read values
  openrouterApiKey = String(p_or_key.getValue());
  apiKey = String(p_weather_key.getValue());
  city = String(p_city.getValue());
  countryCode = String(p_country.getValue());
  tzOffsetMinutes = atoi(p_tzm.getValue());

  worldCity1 = String(p_wc1.getValue());
  worldCity2 = String(p_wc2.getValue());
  worldOffset1 = atoi(p_wo1.getValue());
  worldOffset2 = atoi(p_wo2.getValue());

  // Trim
  openrouterApiKey.trim();
  apiKey.trim();
  city.trim();
  countryCode.trim();
  worldCity1.trim();
  worldCity2.trim();

  // Defaults & clamps
  if (city.length() == 0) city = "Dhaka";
  if (countryCode.length() == 0) countryCode = "BD";
  if (tzOffsetMinutes < -720) tzOffsetMinutes = -720;
  if (tzOffsetMinutes > 840) tzOffsetMinutes = 840;

  if (worldCity1.length() == 0) worldCity1 = "New York";
  if (worldCity2.length() == 0) worldCity2 = "London";
  if (worldOffset1 < -720) worldOffset1 = -720;
  if (worldOffset1 > 840) worldOffset1 = 840;
  if (worldOffset2 < -720) worldOffset2 = -720;
  if (worldOffset2 > 840) worldOffset2 = 840;

  savePreferences();

  display.clearDisplay();
  if (ok) drawCenteredText("Saved & Connected", 26);
  else drawCenteredText("Portal Closed", 26);
  display.display();
  delay(700);

  // Apply new timezone immediately (universal)
  configTime((long)tzOffsetMinutes * 60L, 0, ntpServer);

  // Refresh weather immediately after save
  getWeatherAndForecast();
  lastWeatherUpdate = millis();

  return ok;
}

void connectWiFiWithPortal() {
  runWiFiManagerPortal(true);
}

void enterConfigModeFromPage0() {
  // Clean UI
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  drawCenteredText("Config Mode", 20);
  drawCenteredText("Connect AP:", 40);
  drawCenteredText("DeskBuddy-Setup", 55);
  display.display();

  // Run portal
  runWiFiManagerPortal(false);

  // Return to page0 eyes after config
  currentPage = 0;
  lastPageSwitch = millis();
  lastSaccade = 0;
}

// ==================================================
// 15. SETUP / LOOP
// ==================================================
void setup() {
  Wire.begin(SDA_PIN, SCL_PIN);
  pinMode(TOUCH_PIN, INPUT_PULLDOWN);

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.setTextColor(SSD1306_WHITE);

  leftEye.init(18, 14, 36, 36);
  rightEye.init(74, 14, 36, 36);

  playBootAnimation();

  connectWiFiWithPortal();

  // UNIVERSAL timezone (offset minutes)
  configTime((long)tzOffsetMinutes * 60L, 0, ntpServer);

  getWeatherAndForecast();
  lastWeatherUpdate = millis();
  lastPageSwitch = millis();

  pomoResetToMode();
}

void loop() {
  unsigned long now = millis();

  handleTouch();

  if (now - lastWeatherUpdate > 600000) {
    getWeatherAndForecast();
    lastWeatherUpdate = now;
  }

  if (!aiPopupActive && currentPage < 3 && now - lastPageSwitch > PAGE_INTERVAL) {
    currentPage++;
    if (currentPage > 2) currentPage = 0;
    lastPageSwitch = now;
    lastSaccade = 0;
  }

  display.clearDisplay();

  if (aiPopupActive) {
    if (now - aiPopupStart > AI_POPUP_SHOW_MS) {
      closeAiPopup();
    } else {
      drawAiPopup();
      display.display();
      return;
    }
  }

  switch (currentPage) {
    case 0: drawEmoPage(); break;
    case 1: drawClock(); break;
    case 2: drawWeatherCard(); break;
    case 3: drawWorldClock(); break;
    case 4: drawForecastPage(); break;
    case 5: drawPomodoroPage(); break;
  }

  display.display();
}
