void handleTouch() {
  bool currentPinState = digitalRead(TOUCH_PIN);
  unsigned long now = millis();

  if (currentPinState && !lastPinState) {
    pressStartTime = now;
    isLongPressHandled = false;
  }
  else if (currentPinState && lastPinState) {

    // If AI popup is active, long press scrolls down
    if (aiPopupActive && !isLongPressHandled) {
      if (now - pressStartTime > LONG_PRESS_TIME) {
        if (aiScrollOffset < maxScrollOffset) aiScrollOffset++;
        isLongPressHandled = true;
        lastPageSwitch = now;
        return;
      }
    }
    // Extra-long press for AI (only on pages other than 0 and 5) when popup not active
    else if (!isLongPressHandled && !aiPopupActive && currentPage != 0 && currentPage != 5) {
      if (now - pressStartTime > EXTRA_LONG_PRESS_TIME) {
        startAiPopupIfAllowed();
        isLongPressHandled = true;
        lastPageSwitch = now;
      }
    }
    // Long press (800ms) for other actions (only if popup not active)
    else if (!isLongPressHandled && !aiPopupActive && (now - pressStartTime > LONG_PRESS_TIME)) {
      if (currentPage == 5) {
        currentPage = 0;
        isLongPressHandled = true;
        lastPageSwitch = now;
      } else if (currentPage == 0) {
        // page0 mood cycle
        currentMood++;
        if (currentMood > MOOD_SUSPICIOUS) currentMood = 0;
        lastSaccade = 0;
        isLongPressHandled = true;
        lastPageSwitch = now;
      } else if (currentPage == 1) {
        currentPage = 3;
        isLongPressHandled = true;
        lastPageSwitch = now;
      } else if (currentPage == 2) {
        currentPage = 4;
        isLongPressHandled = true;
        lastPageSwitch = now;
      }
    }
  }
  else if (!currentPinState && lastPinState) {
    // Released
    if ((now - pressStartTime < LONG_PRESS_TIME) && !isLongPressHandled) {
      tapCounter++;
      lastTapTime = now;
    }
  }

  lastPinState = currentPinState;

  if (tapCounter > 0) {
    if (now - lastTapTime > MULTI_TAP_DELAY) {
      lastPageSwitch = now;

      if (aiPopupActive) {
        closeAiPopup();
        tapCounter = 0;
        return;
      }

      // ✅ NEW: TRIPLE TAP only on Page-0 => Config Mode
      if (tapCounter >= 3) {
        if (currentPage == 0) {
          tapCounter = 0;
          enterConfigModeFromPage0();
          return;
        }
        // If triple-tap on other pages: ignore (keeps behavior clean)
        tapCounter = 0;
        return;
      }

      if (tapCounter == 2) {
        if (currentPage == 5) {
          handlePomodoroTapActions(2);
        } else {
          highBrightness = !highBrightness;
          display.ssd1306_command(SSD1306_SETCONTRAST);
          display.ssd1306_command(highBrightness ? 0xFF : 0x20);
        }
      } else if (tapCounter == 1) {
        if (currentPage == 5) {
          handlePomodoroTapActions(1);
        } else {
          currentPage = (currentPage + 1) % 6;
        }
      }
      tapCounter = 0;
    }
  }
}

